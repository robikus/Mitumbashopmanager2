# backend/.env.local.example
# Copy to .env.local for local development.
# This file is gitignored — never commit secrets.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=dev-only-secret-key-change-for-production

# Local PostgreSQL (run: createdb mitumba_dev && createuser mitumba_user)
DATABASE_URL=postgresql://mitumba_user:devpassword@localhost:5432/mitumba_dev

# Cognito — copy from terraform output (or AWS console) after infra is deployed
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_APP_CLIENT_SECRET=your-app-client-secret
COGNITO_DOMAIN=https://your-domain-prefix.auth.us-east-1.amazoncognito.com

# Used to construct callback URLs — must match Cognito app client config
APP_DOMAIN=http://localhost:8000
